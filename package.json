{
  "name": "ppt2html-v3",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "一句话生成精美 HTML 课件，浏览器里像 PPT 一样播放（PWA）",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host",
    "typecheck": "tsc -b",
    "icons": "node scripts/gen-icons.mjs",
    "eval": "node scripts/eval/run-eval.mjs"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "sharp": "^0.35.3",
    "typescript": "^6.0.3",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0"
  },
  "dependencies": {
    "dompurify": "^3.4.11",
    "idb": "^8.0.3",
    "jszip": "^3.10.1",
    "marked": "^18.0.5",
    "pptxgenjs": "^4.0.1",
    "qrcode-generator": "^2.0.4",
    "reveal.js": "^6.0.1"
  }
}
